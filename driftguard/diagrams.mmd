%% DriftGuard Architecture and Flow Diagrams (Mermaid)

%% 1. Context Diagram
flowchart LR
    subgraph Users
        Admin[Administrator]
        Operator[Operator (DevOps/SRE)]
        Viewer[Viewer / Stakeholder]
    end

    subgraph Cluster[Runtime Environment]
        subgraph K8s[Kubernetes / Host]
            API[FastAPI Backend Service]
            FE[React Frontend (SPA)]
            DB[(SQLite Database)]
            Cron[Drift Detection CronJob]
        end
    end

    subgraph IaC[Infrastructure-as-Code & Cloud]
        Repo["IaC Repo (e.g., Terraform)"]
